<!--
This page contains the form for creating a new blog post.
It includes the header and footer partials.
-->
<!DOCTYPE html>
<html>
<head>
    <title>Create New Post</title>
    <link rel="stylesheet" href="/style/styles.css">
</head>
<body>
    <!-- Include the header partial -->
    <%- include('partials/header.ejs') %>

    <div class="content-wrap">
        <div class="container">
            <h1>Create New Post</h1>
            <% if (locals.error) { %>
                <p class="error"><%= error %></p>
            <% } %>
            <!-- Form to submit a new post -->
            <form action="/posts" method="POST">
                <div>
                    <label for="title">Title:</label>
                    <input type="text" id="title" name="postTitle" placeholder="Post Title" value="<%= locals.title || '' %>">
                </div>
                <div>
                    <label for="author">Author:</label>
                    <input type="text" id="author" name="author" placeholder="Author's Name" value="<%= locals.author || '' %>">
                </div>
                <div>
                    <label for="content">Content:</label>
                    <textarea id="content" name="postContent" rows="10" placeholder="Post Content"><%= locals.content || '' %></textarea>
                </div>
                <button type="submit">Publish</button>
                <a href="/">Cancel</a>
            </form>
        </div>
    </div>

    <!-- Include the footer partial -->
    <%- include('partials/footer.ejs') %>
</body>
</html>