<!--
This page contains the form for editing an existing blog post.
It includes the header and footer partials.
-->
<!DOCTYPE html>
<html>
<head>
    <title>Edit Post</title>
    <link rel="stylesheet" href="/style/styles.css">
</head>
<body>
    <!-- Include the header partial -->
    <%- include('partials/header.ejs') %>

    <div class="content-wrap">
        <div class="container">
            <h1>Edit Post</h1>
            <% if (locals.error) { %>
                <p class="error"><%= error %></p>
            <% } %>
            <!-- Form to update an existing post -->
            <form action="/posts/update/<%= post.id %>" method="POST">
                <div>
                    <label for="title">Title:</label>
                    <input type="text" id="title" name="postTitle" value="<%= post.title %>">
                </div>
                <div>
                    <label for="author">Author:</label>
                    <input type="text" id="author" name="author" value="<%= post.author %>">
                </div>
                <div>
                    <label for="content">Content:</label>
                    <textarea id="content" name="postContent" rows="10"><%= post.content %></textarea>
                </div>
                <button type="submit">Save Changes</button>
                <a href="/">Cancel</a>
            </form>
        </div>
    </div>

    <!-- Include the footer partial -->
    <%- include('partials/footer.ejs') %>
</body>
</html>